{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://creature-forge/schemas/asset_spec.schema.json",
  "title": "asset_spec",
  "description": "Stage-1 output: the prompt compiled into a strict, machine-checkable spec.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "prompt",
    "style",
    "archetype",
    "seed",
    "units",
    "up",
    "forward",
    "target_height_m",
    "tri_budget",
    "vert_budget",
    "texture_budget_px",
    "material_model",
    "locomotion",
    "animations"
  ],
  "properties": {
    "spec_version": { "type": "string" },
    "prompt": { "type": "string", "minLength": 1 },
    "style": { "type": "string", "minLength": 1 },
    "archetype": { "type": "string", "enum": ["arachnid", "quadruped", "humanoid"] },
    "seed": { "type": "integer", "minimum": 0 },
    "units": { "const": "m" },
    "up": { "const": "+Y" },
    "forward": { "const": "-Z" },
    "target_height_m": { "type": "number", "exclusiveMinimum": 0, "maximum": 50 },
    "tri_budget": { "type": "integer", "minimum": 1 },
    "vert_budget": { "type": "integer", "minimum": 1 },
    "texture_budget_px": { "type": ["integer", "null"], "minimum": 0 },
    "material_model": { "type": "string", "enum": ["vertex-color", "albedo", "pbr"] },
    "palette": { "type": "string" },
    "limbs": { "type": "integer", "minimum": 0 },
    "locomotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in_place"],
      "properties": { "in_place": { "const": true } }
    },
    "animations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "export": { "type": "string" }
  }
}
